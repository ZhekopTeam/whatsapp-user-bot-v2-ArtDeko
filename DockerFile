FROM golang:1.24-bookworm AS go-builder

WORKDIR /src
ENV GOTOOLCHAIN=auto

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 GOOS=linux GOARCH=amd64 go build -o /out/wa-user-bot ./

FROM python:3.12-slim AS py-builder

WORKDIR /build

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY admin-tg-bot/requirements.txt .
RUN python -m venv /opt/venv \
    && /opt/venv/bin/python -m pip install --upgrade pip \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

FROM python:3.12-slim AS runtime

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates tzdata \
    && rm -rf /var/lib/apt/lists/*

COPY --from=go-builder /out/wa-user-bot /app/wa-user-bot
COPY --from=go-builder /src/data/sentences_list.json /app/data/sentences_list.json

COPY --from=py-builder /opt/venv /opt/venv

COPY admin-tg-bot/ /admin-tg-bot

RUN mkdir -p /app/data /app/sessions /admin-tg-bot/data /admin-tg-bot/sessions

ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/admin-tg-bot \
    WHATSAPP_BIN=/app/wa-user-bot \
    ADMIN_DB_PATH=/admin-tg-bot/data/wa_bot_accounts.db \
    DATABASE_PATH=/admin-tg-bot/data/wa_bot_accounts.db \
    TZ=UTC

ENTRYPOINT ["/app/wa-user-bot"]

