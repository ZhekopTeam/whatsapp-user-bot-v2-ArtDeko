BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMINS=123456789,987654321

# --- Google Sheets Config ---
SPREADSHEET_ID=YOUR_GOOGLE_SPREADSHEET_ID_HERE
CREDENTIALS_PATH=data/service_account.json
SENTENCES_PATH=data/sentences_list.json
ACCOUNTS_SHEET_NAME=WhatsApp Accounts
COMMUNICATIONS_SHEET_NAME=WhatsApp Communications
# Same names are also read as SHEET_ACCOUNTS / SHEET_COMMUNICATIONS by the Telegram bot.

# --- Warmup Scheduler Config ---
FIRST_MESSAGE_WINDOW_START=10:00
FIRST_MESSAGE_WINDOW_END=14:00
REPLY_DELAY_MIN_MINUTES=1
REPLY_DELAY_MAX_MINUTES=6
BOT_TIMEZONE=Europe/Moscow

# --- Advanced Paths (Optional / Docker defaults) ---
# Must be the SAME file for Go (api) and Python (bot).
# ADMIN_DB_PATH=/admin-tg-bot/data/wa_bot_accounts.db
# DATABASE_PATH=/admin-tg-bot/data/wa_bot_accounts.db
# RUNTIME_DB_PATH=sessions/runtime.db
# SESSION_DB_PATH=file:sessions/multi.db?_foreign_keys=on
# WHATSAPP_API_URL=http://api:5001
# API_PORT=5001
